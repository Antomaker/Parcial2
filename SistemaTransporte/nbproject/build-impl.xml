<?xml version="1.0" encoding="UTF-8"?>
<project xmlns:j2seproject3="http://www.netbeans.org/ns/j2se-project/3"
         xmlns:jaxrpc="http://www.netbeans.org/ns/j2se-project/jax-rpc"
         basedir=".."
         default="default"
         name="SistemaTransporte-impl">

    <property file="nbproject/private/config.properties"/>
    <property file="nbproject/private/configs/${config}.properties"/>
    <property file="nbproject/private/private.properties"/>
    <property file="nbproject/configs/${config}.properties"/>
    <property file="nbproject/project.properties"/>

    <target name="default" depends="test,jar,javadoc" description="Build and test whole project."/>

    <target name="-pre-init"/>
    <target name="-init-private"/>
    <target name="-init-user"/>
    <target name="-init-project"/>
    <target name="-do-init"/>
    <target name="-post-init"/>
    <target name="-init-check"/>
    <target name="-init-macrodef-property"/>
    <target name="-init-macrodef-javac-with-processors"/>
    <target name="-init-macrodef-javac-without-processors"/>
    <target name="-init-macrodef-javac"/>
    <target name="-init-macrodef-test"/>
    <target name="-init-macrodef-test-debug"/>
    <target name="-init-macrodef-nbjpdastart"/>
    <target name="-init-macrodef-junit-init"/>
    <target name="-init-macrodef-junit"/>
    <target name="-init-macrodef-junit-debug"/>
    <target name="-init-macrodef-junit-debug-2"/>
    <target name="-init-macrodef-nbjpdaappreloaded"/>
    <target name="-init-source-module-properties"/>

    <target depends="-pre-init,-init-private,-init-user,-init-project,-do-init" name="-init-presetdef"/>
    <target depends="-init-presetdef,-init-macrodef-property,-init-macrodef-javac,-init-macrodef-test,-init-macrodef-test-debug,-init-macrodef-nbjpdastart,-init-macrodef-junit,-init-macrodef-junit-debug,-init-source-module-properties,-init-check" name="init"/>

    <target name="compile" depends="init">
        <mkdir dir="${build.classes.dir}"/>
        <javac srcdir="${src.dir}" destdir="${build.classes.dir}"
               source="${javac.source}" target="${javac.target}"
               encoding="${source.encoding}" includeantruntime="false">
            <classpath path="${javac.classpath}"/>
        </javac>
    </target>

    <target name="jar" depends="compile">
        <mkdir dir="${dist.dir}"/>
        <jar jarfile="${dist.jar}" manifest="${manifest.file}">
            <fileset dir="${build.classes.dir}"/>
            <manifest>
                <attribute name="Main-Class" value="${main.class}"/>
            </manifest>
        </jar>
    </target>

    <target name="run" depends="compile">
        <java classname="${main.class}" fork="true">
            <classpath>
                <pathelement path="${run.classpath}"/>
            </classpath>
        </java>
    </target>

    <target name="clean">
        <delete dir="${build.dir}"/>
        <delete dir="${dist.dir}"/>
    </target>

    <target name="test"/>
    <target name="javadoc"/>
</project>
